# 무역풍 환경변수 예시 — 복사해 .env 로 사용
# 데모는 이 값들 없이도 100% 동작(스냅샷·자체 NLG). 아래는 실데이터·국산 LLM 연동용.

# 관세청 공공데이터포털 인증키 (품목별 국가별 수출입실적 API)
# 발급: https://www.data.go.kr/data/15100475/openapi.do
DATA_GO_KR_KEY=

# 국산 LLM 연동(AI 무역참모 운영 모드). 미설정 시 근거기반 데모 NLG 사용.
# 예) solar | hyperclova
TW_LLM_PROVIDER=
TW_LLM_KEY=

# API CORS 허용 출처 (기본 *)
TW_CORS=*
