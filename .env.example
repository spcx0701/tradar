# 무역풍 환경변수 예시 — .env 로 사용하면 서버/동기화 스크립트가 자동 로딩
# 데모는 이 값들 없이도 100% 동작(스냅샷·자체 NLG). 아래는 실데이터·국산 LLM 연동용.

# 관세청 공공데이터포털 인증키 (품목별 국가별 수출입실적 API)
# 발급: https://www.data.go.kr/data/15100475/openapi.do
# 산업부 산하기관 API(K-SURE 국별신용등급·KOTRA 해외시장뉴스, scripts/sync_motie_data.py)도 이 키를 공용.
DATA_GO_KR_KEY=

# (선택) 산업부 산하기관 API 엔드포인트 재지정 — 기관 개편/버전 변경 시만 필요
# TW_MOTIE_KSURE_GRADE_URL= / TW_MOTIE_KSURE_RISK_URL= / TW_MOTIE_KOTRA_NEWS_URL= / TW_MOTIE_KOTRA_REGS_URL=

# 거래 인텔리전스 자동수집용 공개 B/L/업로드 CSV
# 예: server/data/public_bl_sample.csv
TRADE_INTEL_PUBLIC_BL_CSV=

# 공개 B/L JSON API 어댑터. records/results/data 배열을 반환하는 endpoint.
TRADE_INTEL_PUBLIC_BL_API_URL=
TRADE_INTEL_PUBLIC_BL_API_KEY=

# 자동수집 실행 리포트와 데이터 신선도 기준
TRADE_INTEL_REPORT_OUT=server/data/trade_intel_last_run.json
TRADE_INTEL_STALE_AFTER_HOURS=48
TRADE_INTEL_CUSTOMS_TIMEOUT=8
TRADE_INTEL_CUSTOMS_MARKET_LIMIT=3

# ImportYeti API 사용 시. 공개 예시 endpoint: https://data.importyeti.com/v1.0/company/<company>
IMPORTYETI_API_KEY=

# LLM 연동(AI 무역참모 운영 모드). 미설정 시 근거기반 데모 NLG 사용.
# 기본 예) solar = Upstage Solar, openrouter-solar-free = OpenRouter Solar Pro 3 free,
# gemini-flash = Google Gemini Flash. 모두 OpenAI-compatible Chat Completions 형식으로 호출.
TW_LLM_PROVIDER=openrouter-solar-free
TW_LLM_KEY=
TW_LLM_MODEL=solar-pro3
TW_LLM_BASE_URL=https://api.upstage.ai/v1
TW_LLM_TIMEOUT=12

# provider별 키. 선택 provider 전용 키가 있으면 TW_LLM_KEY보다 우선 사용.
TW_OPENROUTER_KEY=
TW_OPENROUTER_MODEL=upstage/solar-pro-3:free
TW_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TW_GEMINI_KEY=
TW_GEMINI_MODEL=gemini-3.5-flash
TW_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 관리자 전용 LLM provider 선택 API(`/api/admin/llm-provider`) 토큰.
TW_ADMIN_TOKEN=

# Android 앱/정적 Pages가 호출할 서버 API base. 빌드 시 -PtradewindApiBase 로도 지정 가능.
# Render 단일 오리진 배포 기본값: https://tradar.onrender.com/api
TRADEWIND_API_BASE=https://tradar.onrender.com/api
TRADAR_DATA_BASE=https://tradar.onrender.com/data

# API CORS 허용 출처 (기본 *)
TW_CORS=*
