{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|shape|rank|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, shape, rank, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|square)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|outline|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, solid, outline, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|info|positive|negative|warning)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'info' | 'positive' | 'negative' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|loading|disabled|leadingIcon|trailingIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, loading, disabled, leadingIcon, trailingIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|size|outline|active|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, size, outline, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|leadingIcon|invalid|disabled|hint|errorText|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, leadingIcon, invalid, disabled, hint, errorText."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaFormat|sub|icon|spark|size|card|key|ref|className|style|children)$/]",
        "message": "<MetricStat> doesn't accept that prop. Declared props: label, value, delta, deltaFormat, sub, icon, spark, size, card."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute[name.name='deltaFormat'] > Literal[value!=/^(?:percent|signed|number)$/]",
        "message": "<MetricStat> deltaFormat must be one of 'percent' | 'signed' | 'number'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<MetricStat> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlatformIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:platform|size|chip|key|ref|className|style|children)$/]",
        "message": "<PlatformIcon> doesn't accept that prop. Declared props: platform, size, chip."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|thickness|label|color|key|ref|className|style|children)$/]",
        "message": "<ScoreRing> doesn't accept that prop. Declared props: value, max, size, thickness, label, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: size, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Select> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|color|fill|showDot|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, color, fill, showDot, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|solid|key|ref|className|style|children)$/]",
        "message": "<StageBadge> doesn't accept that prop. Declared props: stage, solid."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|count|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: label, value, count, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|selected|onRemove|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: color, selected, onRemove, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendDelta'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|format|size|pill|showArrow|key|ref|className|style|children)$/]",
        "message": "<TrendDelta> doesn't accept that prop. Declared props: value, format, size, pill, showArrow."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendDelta'] > JSXAttribute[name.name='format'] > Literal[value!=/^(?:percent|signed|number)$/]",
        "message": "<TrendDelta> format must be one of 'percent' | 'signed' | 'number'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendDelta'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<TrendDelta> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
